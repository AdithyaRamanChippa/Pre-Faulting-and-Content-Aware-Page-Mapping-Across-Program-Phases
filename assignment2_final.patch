diff --git a/include/linux/phase_map.h b/include/linux/phase_map.h
new file mode 100644
index 000000000..d04f919f2
--- /dev/null
+++ b/include/linux/phase_map.h
@@ -0,0 +1,21 @@
+#ifndef _LINUX_PHASE_MAP_H
+#define _LINUX_PHASE_MAP_H
+
+#include <linux/types.h>
+#include <linux/mm_types.h>
+
+struct phase_map_info {
+    unsigned long  buff1_start;
+    unsigned long  buff2_start;
+    size_t         len;
+    unsigned long  num_pages;
+    unsigned long *accessed_bitmap;
+};
+
+extern struct phase_map_info *phase_info;
+
+void phase_map_mirror_page(struct vm_area_struct *vma,
+                           unsigned long fault_addr,
+                           struct page *page);
+#endif
+
